    "api_key_env": "PRODUCT_STAGING_API_KEY",
    "default_model": "product-model",
    "provider": "product",
    "system_prompt": "Follow the eval instructions exactly.",
    "timeout_ms": 30000,
    "retry": {
      "max_attempts": 3,
      "backoff_ms": 500,
      "retry_on_status": [429, 500, 502, 503, 504]
    }
  }
]
